<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">
  <Id>132194d4-7031-468b-9c8f-c0edb60601d9</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Apolla</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Apolla Capture"/>
  <Description DefaultValue="Capture this email to Viktora Apolla. Click Capture on any email to ingest it into your Apolla corpus."/>
  <IconUrl DefaultValue="https://rosscantrell.github.io/apolla-outlook-addin/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://rosscantrell.github.io/apolla-outlook-addin/icon-80.png"/>
  <SupportUrl DefaultValue="https://viktora.ai"/>
  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.5"/>
    </Sets>
  </Requirements>
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://rosscantrell.github.io/apolla-outlook-addin/taskpane.html"/>
        <RequestedHeight>250</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>
  <Permissions>ReadItem</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>
  <DisableEntityHighlighting>false</DisableEntityHighlighting>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">
      <Requirements>
        <bt:Sets DefaultMinVersion="1.5">
          <bt:Set Name="Mailbox"/>
        </bt:Sets>
      </Requirements>
      <Hosts>
        <Host xsi:type="MailHost">
          <DesktopFormFactor>
            <FunctionFile resid="functionFile"/>
            <ExtensionPoint xsi:type="MessageReadCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="apollaGroup">
                  <Label resid="groupLabel"/>
                  <!-- D-ADDIN-10: Capture button (ExecuteFunction, silent) -->
                  <Control xsi:type="Button" id="apollaCaptureBtn">
                    <Label resid="captureLabel"/>
                    <Supertip>
                      <Title resid="captureLabel"/>
                      <Description resid="captureDesc"/>
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="icon16"/>
                      <bt:Image size="32" resid="icon32"/>
                      <bt:Image size="80" resid="icon80"/>
                    </Icon>
                    <Action xsi:type="ExecuteFunction">
                      <FunctionName>captureEmail</FunctionName>
                    </Action>
                  </Control>
                  <!-- D-ADDIN-10: Configure button (ShowTaskpane) -->
                  <Control xsi:type="Button" id="apollaConfigureBtn">
                    <Label resid="configureLabel"/>
                    <Supertip>
                      <Title resid="configureLabel"/>
                      <Description resid="configureDesc"/>
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="icon16"/>
                      <bt:Image size="32" resid="icon32"/>
                      <bt:Image size="80" resid="icon80"/>
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <SourceLocation resid="configurePane"/>
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>
          </DesktopFormFactor>
        </Host>
      </Hosts>
      <Resources>
        <bt:Images>
          <bt:Image id="icon16" DefaultValue="https://rosscantrell.github.io/apolla-outlook-addin/icon-16.png"/>
          <bt:Image id="icon32" DefaultValue="https://rosscantrell.github.io/apolla-outlook-addin/icon-32.png"/>
          <bt:Image id="icon80" DefaultValue="https://rosscantrell.github.io/apolla-outlook-addin/icon-80.png"/>
        </bt:Images>
        <bt:Urls>
          <bt:Url id="functionFile" DefaultValue="https://rosscantrell.github.io/apolla-outlook-addin/functions.html"/>
          <bt:Url id="configurePane" DefaultValue="https://rosscantrell.github.io/apolla-outlook-addin/configure.html"/>
        </bt:Urls>
        <bt:ShortStrings>
          <bt:String id="groupLabel" DefaultValue="Apolla"/>
          <bt:String id="captureLabel" DefaultValue="Capture"/>
          <bt:String id="configureLabel" DefaultValue="Configure"/>
        </bt:ShortStrings>
        <bt:LongStrings>
          <bt:String id="captureDesc" DefaultValue="Capture this email to Viktora Apolla"/>
          <bt:String id="configureDesc" DefaultValue="Configure Apolla server URL and bearer token"/>
        </bt:LongStrings>
      </Resources>
    </VersionOverrides>
  </VersionOverrides>
</OfficeApp>
